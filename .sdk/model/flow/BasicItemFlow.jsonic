# BasicItemFlow

main: kit: flow: BasicItemFlow:
{
  entity: "item",
  kind: "basic",
  name: "BasicItemFlow",
  step: [
    {
      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "item_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "item_ref01",
        srcdatavar: "item_ref01_data",
        suffix: "_dt0"
      }

      match: {
        id: "item01"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-item_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicItemFlow"
}